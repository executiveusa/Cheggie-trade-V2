# ============================================================
# SYNTHIA™ SOVEREIGN STUDIO — Environment Variables
# Copy this file to .env.local and fill in all required values
# NEVER commit .env.local to git
# ============================================================

# ── APP ─────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — NEVER expose to browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── ANTHROPIC ────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── MUAPI (Media Generation) ──────────────────────────────────
# Get from: muapi.ai → Dashboard → API Keys
MUAPI_DEFAULT_KEY=muapi-...
# Optional: override the base URL if self-hosting muapi
# MUAPI_BASE_URL=https://api.muapi.ai

# ── CREEM (Payments) ─────────────────────────────────────────
# Get from: creem.io → Dashboard → Products
# Create 3 one-time products and paste their IDs here
CREEM_STARTER_ID=prod_...
CREEM_PRO_ID=prod_...
CREEM_OPERATOR_ID=prod_...
# Get from: creem.io → Dashboard → Webhooks → Signing Secret
CREEM_WEBHOOK_SECRET=whsec_...

# ── SCREENSHOTONE (UDEC Visual Audit) ────────────────────────
# Get from: screenshotone.com → Dashboard → Access Key
# Optional — without this, UDEC audit uses text-only analysis
SCREENSHOTONE_KEY=...

# ── WHATSAPP BUSINESS (Optional) ─────────────────────────────
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
# Requires Meta Business Verification (takes 2-6 weeks)
WHATSAPP_TOKEN=EAAxxxxx...
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_VERIFY_TOKEN=your-random-verify-string

# ── WHITE LABEL (Optional) ───────────────────────────────────
# Override brand identity for agency/reseller deployments
# Leave blank to use default Synthia™ branding
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_BRAND_COLOR=
